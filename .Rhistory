#15-month-ahead point forecast and 80%/95% prediction intervals from SARIMA(3,0,0)(0,1,2)[12] (M6).
#Forecasts are back-transformed to AUD millions."
library(forecast)
frc_m6 <- forecast::forecast(m300_ml, h = 15)
plot(frc_m6, main = "Forecast: SARIMA(3,0,0)(0,1,2)[12]",
xlab = "Year", ylab = "AUD (Million)",
fcol = "red", flwd = 1.5)
lines(stats::lag(fitted(m300_ml), -1), col = "blue", lwd = 1.2)
legend("topright", lty = 1, pch = c(1, NA),
col = c("black", "blue", "red"),
legend = c("Observed", "Fitted", "Forecast"),
cex = 0.75, bty = "n", text.width = 11)
frc_m6_df           <- as.data.frame(frc_m6)
