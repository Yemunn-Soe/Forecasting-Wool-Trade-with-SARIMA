# The symbol 'o' denotes entries consistent with white noise; 'x' denotes significant autocorrelation.
# The vertex of the upper-left triangle of 'o' values identifies the candidate ARMA(p, q) order."
eacf_res <- eacf(res_m2, ar.max = 7, ma.max = 13)
#| fig-height: 4
#| fig-width: 7
#BIC-optimal subset ARMA model selection on the SARIMA(0,0,0)(0,1,2)[12] residuals.
#Shaded cells indicate terms selected by BIC; darker shading = lower BIC.
res_bic <- armasubsets(y = res_m2, nar = 10, nma = 10,
y.name = "res", ar.method = "ols")
plot(res_bic)
#| fig-height: 4
