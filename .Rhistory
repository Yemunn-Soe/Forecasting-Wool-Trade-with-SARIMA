# Create the information criteria table
make_ic_table <- function(model_list, labels) {
data.frame(
Model = labels,
df    = sapply(model_list, function(m) length(m$coef) + 1L),
AIC   = round(sapply(model_list, AIC), 3),
BIC   = round(sapply(model_list, BIC), 3),
row.names = NULL
)
}
# Generate the full table
ic_df <- make_ic_table(models_ml, model_labels_ml)
# Create AIC-only table (sorted by AIC)
aic_table <- ic_df[order(ic_df$AIC), c("Model", "df", "AIC")]
# Create BIC-only table (sorted by BIC)
bic_table <- ic_df[order(ic_df$BIC), c("Model", "df", "BIC")]
# Display AIC table
knitr::kable(aic_table,
caption = "Table 28. AIC values for candidate models (ML method), sorted by AIC (ascending = better fit).",
align = "lccc",
row.names = FALSE,
digits = 3,
booktabs = TRUE)
# Display BIC table
knitr::kable(bic_table,
caption = "Table 29. BIC values for candidate models (ML method), sorted by BIC (ascending = better fit).",
align = "lcc",
row.names = FALSE,
digits = 3,
booktabs = TRUE)
