frc_m6_df$Month     <- rownames(frc_m6_df)
frc_m6_df           <- frc_m6_df[, c("Month", "Point Forecast",
"Lo 80", "Hi 80", "Lo 95", "Hi 95")]
knitr::kable(frc_m6_df,
caption   = "15-month-ahead forecasts from SARIMA(3,0,0)(0,1,2)[12] (M6), with 80% and 95% prediction intervals (AUD millions).",
align     = "lrrrrr", row.names = FALSE, booktabs = TRUE)
#| results: asis
#| echo: false
all_chunks <- knitr::all_labels()
all_chunks <- all_chunks[all_chunks != "appendix"]
for (chunk_name in all_chunks) {
chunk_content <- knitr::knit_code$get(chunk_name)
cat("\n\n### Chunk:", chunk_name, "\n")
if (!is.null(chunk_content) && length(chunk_content) > 0) {
cat("```r\n")
cat(chunk_content, sep = "\n")
cat("\n```\n")
} else {
cat("*Code not available.*\n")
}
}
