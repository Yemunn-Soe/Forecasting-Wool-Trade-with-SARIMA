candidate_models <- data.frame(
Label = c("M100", "M102", "M103", "M200", "M202", "M203", "M300", "M405"),
Specification = c(
"SARIMA$(1,0,0)(0,1,2)[12]",
"SARIMA$(1,0,2)(0,1,2)[12]",
"SARIMA$(1,0,3)(0,1,2)[12]",
"SARIMA$(2,0,0)(0,1,2)[12]",
"SARIMA$(2,0,2)(0,1,2)[12]",
"SARIMA$(2,0,3)(0,1,2)[12]",
"SARIMA$(3,0,0)(0,1,2)[12]",
"SARIMA$(4,0,5)(0,1,2)[12]"
),
`Non-seasonal params` = c(3, 5, 6, 4, 6, 7, 5, 11)
)
# Create the table
kable(candidate_models,
caption = "Candidate SARIMA models with seasonal component (0,1,2){12}.",
align = c("l", "l", "c"),
escape = FALSE,
booktabs = TRUE) %>%
kable_styling(latex_options = c("hold_position", "striped"))
